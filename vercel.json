{
  "buildCommand": "pip install -r backend/requirements.txt && cd frontend && npm install && npm run build",
  "installCommand": "npm install --prefix frontend",
  "outputDirectory": "frontend/dist",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.py"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "env": {
    "FLASK_ENV": "production",
    "PYTHONUNBUFFERED": "1"
  },
  "functions": {
    "api/index.py": {
      "runtime": "python@3.9",
      "memory": 512,
      "maxDuration": 30
    }
  }
}
