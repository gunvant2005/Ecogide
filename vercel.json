{
  "buildCommand": "pip install --break-system-packages -r backend/requirements.txt && cd frontend && npm install && npm run build",
  "installCommand": "npm install --prefix frontend",
  "outputDirectory": "frontend/dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "env": {
    "FLASK_ENV": "production",
    "PYTHONUNBUFFERED": "1",
    "VERCEL": "1"
  }
}
